# Backend environment
# Local SQLite test:
DATABASE_URL=sqlite:///./order_assistant.db

# For online deployment, replace with Neon/Supabase PostgreSQL URL:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

SECRET_KEY=replace-with-a-long-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Local + deployed frontend domains, comma-separated
FRONTEND_ORIGINS=http://localhost:5173,https://your-frontend-domain.vercel.app
